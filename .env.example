# =============================================================================
# WALLA WALLA TRAVEL - Environment Configuration
# Copy this file to .env.local and fill in your values
# Generate secrets with: openssl rand -base64 32
# =============================================================================

# -----------------------------------------------------------------------------
# DATABASE (Required)
# -----------------------------------------------------------------------------
# Supabase PostgreSQL connection (use pooler URL for production/serverless)
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-us-west-2.pooler.supabase.com:6543/postgres"
# Direct connection for Prisma migrations (bypasses PgBouncer)
DIRECT_URL="postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres"
# Prisma ORM — session mode pooler (port 5432) supports prepared statements
# Transaction mode pooler (port 6543) does NOT work with Prisma
PRISMA_DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-us-west-2.pooler.supabase.com:5432/postgres"
# Test database for running tests
TEST_DATABASE_URL="postgresql://postgres:password@localhost:5432/test_db"
# Connection pool tuning (optional — sensible defaults built in)
DB_MAX_CONNECTIONS=20
DB_STATEMENT_TIMEOUT_MS=30000
DB_SLOW_QUERY_THRESHOLD_MS=1000

# -----------------------------------------------------------------------------
# SUPABASE (Required)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://[project-ref].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key
# Alternative key name used in some files
SUPABASE_URL=https://[project-ref].supabase.co

# -----------------------------------------------------------------------------
# SECURITY SECRETS (Required — generate each with: openssl rand -base64 32)
# -----------------------------------------------------------------------------
SESSION_SECRET=generate-a-32-char-secret
JWT_SECRET=generate-a-32-char-secret
CSRF_SECRET=generate-a-32-char-secret
# Secret for authenticating cron job requests
CRON_SECRET=generate-a-32-char-secret
# Secret for calendar feed URL signing
CALENDAR_FEED_SECRET=generate-a-32-char-secret

# -----------------------------------------------------------------------------
# STRIPE PAYMENTS — Default / NW Touring (Required for bookings)
# Get keys from https://dashboard.stripe.com/apikeys
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Webhook secrets from https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_WEBHOOK_SECRET_LIVE=whsec_...

# -----------------------------------------------------------------------------
# STRIPE PAYMENTS — Walla Walla Travel brand
# Separate Stripe account for WWT brand
# -----------------------------------------------------------------------------
STRIPE_WWT_SECRET_KEY=sk_test_...
STRIPE_WWT_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET_WWT_TEST=whsec_...
STRIPE_WEBHOOK_SECRET_WWT_LIVE=whsec_...

# -----------------------------------------------------------------------------
# STRIPE PAYMENTS — NW Touring & Concierge brand
# Explicit brand keys (falls back to default STRIPE_SECRET_KEY if not set)
# -----------------------------------------------------------------------------
STRIPE_NWTOURING_SECRET_KEY=sk_test_...
STRIPE_NWTOURING_PUBLISHABLE_KEY=pk_test_...

# -----------------------------------------------------------------------------
# EMAIL SERVICE (Required for notifications)
# Resend — https://resend.com/api-keys
# -----------------------------------------------------------------------------
RESEND_API_KEY=re_...
FROM_EMAIL=bookings@yourdomain.com
STAFF_NOTIFICATION_EMAIL=info@yourdomain.com
ADMIN_EMAIL=admin@yourdomain.com
SUPERVISOR_EMAIL=supervisor@yourdomain.com
SUPERVISOR_PHONE=+15095551234

# -----------------------------------------------------------------------------
# APPLICATION URLs
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=https://yourdomain.com
NEXT_PUBLIC_SITE_URL=https://yourdomain.com
NEXT_PUBLIC_BASE_URL=https://yourdomain.com
NEXT_PUBLIC_API_URL=https://yourdomain.com/api
NEXT_PUBLIC_TRAVEL_DOMAIN=yourdomain.com
NEXT_PUBLIC_EVENTS_DOMAIN=events.yourdomain.com

# -----------------------------------------------------------------------------
# SMS SERVICE (Optional — for text notifications)
# Twilio — https://console.twilio.com
# -----------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# -----------------------------------------------------------------------------
# AI SERVICES
# -----------------------------------------------------------------------------
# Anthropic Claude — conversational AI, content generation
ANTHROPIC_API_KEY=sk-ant-...
# Google Gemini — structured extraction, vision
GEMINI_API_KEY=your-gemini-key
GOOGLE_AI_API_KEY=your-google-ai-key
# Deepgram — voice/audio transcription
DEEPGRAM_API_KEY=your-deepgram-key
# Model override for smart import feature (optional)
SMART_IMPORT_MODEL=claude-sonnet-4-20250514

# -----------------------------------------------------------------------------
# GOOGLE SERVICES
# -----------------------------------------------------------------------------
# Google Calendar integration (tour scheduling sync)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_CALENDAR_ID=your-calendar-id@group.calendar.google.com
# Google Maps (winery/venue maps)
GOOGLE_MAPS_API_KEY=your-maps-key
# Google Search Console (SEO monitoring)
GOOGLE_SEARCH_CONSOLE_SITE_URL=https://yourdomain.com

# -----------------------------------------------------------------------------
# SOCIAL MEDIA — Buffer integration
# -----------------------------------------------------------------------------
BUFFER_CLIENT_ID=your-buffer-client-id
BUFFER_CLIENT_SECRET=your-buffer-client-secret
NEXT_PUBLIC_BUFFER_CONFIGURED=false

# -----------------------------------------------------------------------------
# MEDIA — Unsplash (stock photos)
# -----------------------------------------------------------------------------
UNSPLASH_ACCESS_KEY=your-unsplash-key

# -----------------------------------------------------------------------------
# ERROR MONITORING — Sentry (Recommended for production)
# https://sentry.io
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
SENTRY_AUTH_TOKEN=sntrys_...
SENTRY_ORG=your-org
SENTRY_PROJECT=your-project

# -----------------------------------------------------------------------------
# RATE LIMITING — Upstash Redis (Optional — has in-memory fallback)
# https://console.upstash.com
# -----------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# -----------------------------------------------------------------------------
# ANALYTICS (Optional)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# -----------------------------------------------------------------------------
# GITHUB ISSUE AUTOMATION (Required for error-to-issue pipeline)
# Fine-grained PAT with issues:write — https://github.com/settings/tokens
# -----------------------------------------------------------------------------
GITHUB_TOKEN=ghp_...
# Repository in owner/repo format
GITHUB_REPOSITORY=your-org/your-repo

# -----------------------------------------------------------------------------
# SENTRY WEBHOOK (Required for Sentry → GitHub issue pipeline)
# From Sentry Internal Integration webhook signing secret
# -----------------------------------------------------------------------------
SENTRY_WEBHOOK_SECRET=generate-a-32-char-secret

# -----------------------------------------------------------------------------
# LOGGING (Optional — defaults to 'info')
# Values: debug, info, warn, error
# -----------------------------------------------------------------------------
LOG_LEVEL=info
